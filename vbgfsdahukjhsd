	if input.UserInputType == Enum.UserInputType.MouseWheel then
		TweenService:Create(scrollWheel, TweenInfo.new(0.05), {BackgroundColor3 = flashColor, BackgroundTransparency = 0}):Play()
		if input.Position.Z > 0 then
			TweenService:Create(scrollUpArrow, TweenInfo.new(0.05), {TextTransparency = 0, TextColor3 = Color3.fromRGB(0, 255, 255)}):Play()
			task.delay(0.15, function()
				TweenService:Create(scrollUpArrow, TweenInfo.new(0.2), {TextTransparency = 1}):Play()
			end)
		else
			TweenService:Create(scrollDownArrow, TweenInfo.new(0.05), {TextTransparency = 0, TextColor3 = Color3.fromRGB(0, 255, 255)}):Play()
			task.delay(0.15, function()
				TweenService:Create(scrollDownArrow, TweenInfo.new(0.2), {TextTransparency = 1}):Play()
			end)
		end
		task.delay(0.1, function()
			TweenService:Create(scrollWheel, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(70, 70, 70), BackgroundTransparency = 0.2}):Play()
		end)
	end
end)

