local longPressThreshold = 0.01
local keyPressTimes = {}

local defaultMouseBtnColor = Color3.fromRGB(50, 50, 50)
local defaultMouseBtnTransparency = 0.3
local activeColor = Color3.fromRGB(0, 255, 255)
local flashColor = Color3.fromRGB(255, 255, 255)
local defaultKeyColor = Color3.fromRGB(50, 50, 50)

local function activateKey(name)
	local button = buttons[name]
	if not button then return end
	keyPressTimes[name] = tick()
	task.spawn(function()
		task.wait(longPressThreshold)
		if keyPressTimes[name] then
			TweenService:Create(button, TweenInfo.new(0.1), {BackgroundColor3 = activeColor}):Play()
		end
	end)
end

local function deactivateKey(name)
	local button = buttons[name]
	if not button or not keyPressTimes[name] then return end
	local pressDuration = tick() - keyPressTimes[name]
	keyPressTimes[name] = nil
	if pressDuration < longPressThreshold then
		TweenService:Create(button, TweenInfo.new(0.1), {BackgroundColor3 = flashColor}):Play()
		task.spawn(function()
			task.wait(0.1)
			if not keyPressTimes[name] then
				TweenService:Create(button, TweenInfo.new(0.1), {BackgroundColor3 = defaultKeyColor}):Play()
			end
		end)
	else
		TweenService:Create(button, TweenInfo.new(0.1), {BackgroundColor3 = defaultKeyColor}):Play()
	end
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if input.UserInputType == Enum.UserInputType.Keyboard then
		local keyDataList = keyCodeToKeys[input.KeyCode]
		if keyDataList then
			for _, keyData in ipairs(keyDataList) do
